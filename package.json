{
  "name": "@lerg96/commait",
  "version": "1.0.1",
  "description": "🚀 AI-powered Git commit message generator with emojis. Analyzes your staged changes and generates concise, descriptive commit messages using OpenAI or your local LLM (LM Studio, Ollama, llama.cpp).",
  "main": "dist/index.js",
  "bin": {
    "commait": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "echo \"Tests coming soon\" && exit 0",
    "lint": "eslint src/",
    "install-hook": "node dist/index.js install-hook",
    "publish": "npm publish"
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "ai-assistant",
    "git-hook",
    "commit-message",
    "llm",
    "openai",
    "emoji",
    "automation"
  ],
  "author": "Luis Romero",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luiseromerog/commait.git"
  },
  "bugs": {
    "url": "https://github.com/luiseromerog/commait/issues"
  },
  "homepage": "https://github.com/luiseromerog/commait#readme",
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "AGENTS.md",
    ".commait.json",
    ".gitignore"
  ]
}
